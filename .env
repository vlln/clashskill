# 安装内核 可选：mihomo、clash
KERNEL_NAME=mihomo

# 安装路径
CLASH_BASE_DIR=~/clashctl

# 机场订阅
CLASH_CONFIG_URL=

# 下载订阅时的 UserAgent
CLASH_SUB_UA=clash-verge/v2.4.0

# init 系统（自动识别）
INIT_TYPE=

# Web UI 下载地址
URL_CLASH_UI_DL=https://github.com/Zephyruso/zashboard/releases/latest/download/dist.zip

# github 加速
URL_GH_PROXY=https://gh-proxy.org

# 公共 Web 控制台
URL_CLASH_UI=http://board.zash.run.place

# 软件版本号
VERSION_MIHOMO=v1.19.17
VERSION_YQ=v4.49.2
VERSION_SUBCONVERTER=v0.9.0

# 节点测试配置
TEST_URL=http://www.gstatic.com/generate_204    # 测试延迟使用的URL
TEST_TIMEOUT=5000                               # 超时时间（毫秒）
TEST_CONCURRENT=5                               # 并发测试数量